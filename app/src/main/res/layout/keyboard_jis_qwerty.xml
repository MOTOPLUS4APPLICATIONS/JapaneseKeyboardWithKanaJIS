<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/frame_keyboard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#2196F3"
    android:orientation="vertical"
    android:paddingStart="6dp"
    android:paddingTop="4dp"
    android:paddingEnd="6dp"
    android:paddingBottom="4dp">

    <!-- Candidate area (segments + candidates) -->
    <LinearLayout
        android:id="@+id/candidates_root"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:visibility="gone">

        <!-- Segment row: adjust buttons + chips (horizontal scroll) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <Button
                android:id="@+id/segment_shrink_right"
                android:layout_width="40dp"
                android:layout_height="match_parent"
                android:padding="0dp"
                android:text="‹" />

            <HorizontalScrollView
                android:id="@+id/segment_container"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:fillViewport="true">

                <LinearLayout
                    android:id="@+id/segment_list"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="horizontal" />
            </HorizontalScrollView>

            <Button
                android:id="@+id/segment_expand_right"
                android:layout_width="40dp"
                android:layout_height="match_parent"
                android:padding="0dp"
                android:text="›" />
        </LinearLayout>

        <!-- Candidates for the focused segment (horizontal scroll) -->
        <HorizontalScrollView
            android:id="@+id/candidate_container"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:fillViewport="true">

            <LinearLayout
                android:id="@+id/candidate_list"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal" />
        </HorizontalScrollView>
    </LinearLayout>

